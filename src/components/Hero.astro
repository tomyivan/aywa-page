---
import LogoCoin from './LogoCoin.astro';
---
<section id="Inicio" class="relative min-h-screen flex items-center overflow-hidden bg-space-dark">

  <!-- Glow blobs -->
  <div class="absolute top-1/3 left-0 w-[500px] h-[500px] bg-brand-turquoise/8 rounded-full blur-[140px] pointer-events-none"></div>
  <div class="absolute bottom-1/4 right-0 w-[400px] h-[400px] bg-space-purple/60 rounded-full blur-[120px] pointer-events-none"></div>

  <!-- Grid de dos columnas -->
  <div class="relative z-10 w-full max-w-7xl mx-auto px-6 pt-24 pb-16 grid grid-cols-1 md:grid-cols-2 gap-12 items-center">

    <!-- Columna izquierda: contenido -->
    <div class="flex flex-col gap-6">

      <!-- Título -->
      <h1 id="hero-title" class="text-5xl lg:text-6xl xl:text-7xl font-bold text-text-main leading-tight">
        Tu mascota,<br/>
        <span class="text-brand-turquoise">siempre conectada</span>
      </h1>

      <!-- Subtítulo -->
      <p id="hero-subtitle" class="text-text-secondary text-lg md:text-xl leading-relaxed max-w-lg">
        GPS en tiempo real, seguimiento de salud y alertas inteligentes. Todo lo que necesitas para cuidar a tu mascota desde tu celular.
      </p>

      <!-- Botones CTA -->
      <div id="hero-cta" class="flex flex-col sm:flex-row gap-4">
        <a
          href="#Descargar"
          class="relative group overflow-hidden flex items-center justify-center gap-3 bg-brand-turquoise text-space-dark font-bold px-8 py-4 rounded-xl text-lg transition-all duration-300 hover:shadow-[0_0_40px_rgba(62,188,164,0.45)] hover:scale-105"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
            <polyline points="7 10 12 15 17 10"/>
            <line x1="12" y1="15" x2="12" y2="3"/>
          </svg>
          Descargar App
          <span class="absolute inset-0 -translate-x-full group-hover:translate-x-full transition-transform duration-700 bg-gradient-to-r from-transparent via-white/20 to-transparent skew-x-12"></span>
        </a>

        <a
          href="#ComoFunciona"
          class="flex items-center justify-center gap-2 border border-text-secondary/30 text-text-secondary px-8 py-4 rounded-xl text-lg hover:border-brand-turquoise hover:text-brand-turquoise transition-all duration-300"
        >
          Cómo funciona
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="9 18 15 12 9 6"/>
          </svg>
        </a>
      </div>

      <!-- Estadísticas -->
      <div id="hero-stats" class="flex flex-wrap gap-8 pt-8 border-t border-text-secondary/10">
        <div>
          <p class="text-3xl font-bold text-text-main">GPS</p>
          <p class="text-text-secondary text-sm mt-1">Tiempo real</p>
        </div>
        <div class="w-px bg-text-secondary/10"></div>
        <div>
          <p class="text-3xl font-bold text-text-main">24/7</p>
          <p class="text-text-secondary text-sm mt-1">Monitoreo</p>
        </div>
        <div class="w-px bg-text-secondary/10"></div>
        <div>
          <p class="text-3xl font-bold text-text-main">∞</p>
          <p class="text-text-secondary text-sm mt-1">Tranquilidad</p>
        </div>
      </div>
    </div>

    <!-- Columna derecha: moneda 3D -->
    <div id="hero-logo" class="flex items-center justify-center">
      <LogoCoin />
    </div>
  </div>

  <!-- Flecha scroll -->
  <div id="hero-scroll" class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-text-secondary/40">
    <span class="text-xs tracking-widest uppercase">Scroll</span>
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="animate-bounce">
      <polyline points="6 9 12 15 18 9" transform="rotate(180 12 12)"/>
    </svg>
  </div>
</section>

<script>
  import gsap from 'gsap';

  const tl = gsap.timeline({ defaults: { ease: 'power3.out' } });

  tl.from('#hero-title',    { x: -60, opacity: 0, duration: 0.9 })
    .from('#hero-subtitle', { x: -40, opacity: 0, duration: 0.8 }, '-=0.6')
    .from('#hero-cta',      { x: -30, opacity: 0, duration: 0.7 }, '-=0.5')
    .from('#hero-stats',    { x: -20, opacity: 0, duration: 0.6 }, '-=0.4')
    .from('#hero-logo',     { x: 60,  opacity: 0, duration: 1.0, ease: 'power2.out' }, '-=1.2')
    .from('#hero-scroll',   { opacity: 0, duration: 0.5 }, '-=0.2');

  // La flotación del logo la maneja Three.js internamente
</script>
