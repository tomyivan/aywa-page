---
import aywaLogo from '../assets/logo.svg?raw';
---
<header id="navbar" class="fixed py-2 top-0 left-0 right-0 z-50 transition-all duration-300">
  <nav class="mx-auto flex items-center justify-between px-6 py-4 max-w-7xl">

    <!-- Logo + nombre -->
    <a href="#Inicio" class="flex items-center gap-3 group">
      <span class="w-9 h-9 text-brand-turquoise transition-transform duration-300 group-hover:scale-110" set:html={aywaLogo} />
      <span class="text-text-main font-bold text-xl tracking-wide">OYWA</span>
    </a>

    <!-- Links centrales -->
    <ul class="hidden md:flex items-center gap-8">
      {[
        { label: 'Inicio',          href: '#Inicio' },
        { label: 'Características', href: '#Caracteristicas' },
        { label: 'Cómo Funciona',   href: '#ComoFunciona' },
        { label: 'Descargar',       href: '#Descargar' },
      ].map(({ label, href }) => (
        <li>
          <a
            href={href}
            class="text-text-secondary text-sm font-medium hover:text-brand-turquoise transition-colors duration-200 relative after:absolute after:bottom-[-2px] after:left-0 after:w-0 after:h-px after:bg-brand-turquoise after:transition-all after:duration-300 hover:after:w-full"
          >
            {label}
          </a>
        </li>
      ))}
    </ul>

    <!-- CTA -->
    <a
      href="#Descargar"
      class="hidden md:flex items-center gap-2 bg-brand-turquoise text-space-dark font-semibold text-sm px-5 py-2.5 rounded-full hover:shadow-[0_0_20px_rgba(62,188,164,0.4)] hover:scale-105 transition-all duration-300"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
        <polyline points="7 10 12 15 17 10"/>
        <line x1="12" y1="15" x2="12" y2="3"/>
      </svg>
      Descargar App
    </a>

    <!-- Hamburguesa mobile -->
    <button id="mobile-menu-btn" class="md:hidden text-text-secondary hover:text-brand-turquoise transition-colors" aria-label="Menú">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="3" y1="6" x2="21" y2="6"/>
        <line x1="3" y1="12" x2="21" y2="12"/>
        <line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-card-navy/95 backdrop-blur-md border-t border-text-secondary/10 px-6 pb-6 pt-2 flex-col gap-4">
    {[
      { label: 'Inicio',          href: '#Inicio' },
      { label: 'Características', href: '#Caracteristicas' },
      { label: 'Cómo Funciona',   href: '#ComoFunciona' },
      { label: 'Descargar',       href: '#Descargar' },
    ].map(({ label, href }) => (
      <a href={href} class="text-text-secondary hover:text-brand-turquoise py-2 text-sm font-medium transition-colors">
        {label}
      </a>
    ))}
    <a href="#Descargar" class="mt-2 flex items-center justify-center gap-2 bg-brand-turquoise text-space-dark font-semibold text-sm px-5 py-3 rounded-full">
      Descargar App
    </a>
  </div>
</header>

