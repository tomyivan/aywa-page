---
const features = [
  {
    title: 'Mascotas Perdidas',
    description: 'Publica el perfil de tu mascota perdida con foto, descripción y última ubicación. La comunidad te ayuda a encontrarla.',
    tag: 'Comunidad',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/><circle cx="11" cy="11" r="3"/></svg>`,
  },
  {
    title: 'Mapa de Ubicación',
    description: 'Si alguien encuentra a tu mascota y la reporta, verás su ubicación exacta en el mapa en tiempo real.',
    tag: 'GPS · Tiempo real',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12S4 16 4 10a8 8 0 1 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>`,
  },
  {
    title: 'Refugios Cercanos',
    description: 'Encuentra refugios, veterinarias y centros de adopción cercanos a tu ubicación para dar o recibir ayuda.',
    tag: 'Directorio',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`,
  },
  {
    title: 'Fotos de tu Mascota',
    description: 'Comparte momentos especiales de tu mascota con la comunidad. Construye el álbum de vida de tu compañero.',
    tag: 'Social',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>`,
  },
];
---

<section id="Caracteristicas" class="relative bg-space-dark py-24 overflow-hidden">

  <div class="absolute top-0 right-0 w-[400px] h-[400px] bg-brand-turquoise/5 rounded-full blur-[120px] pointer-events-none"></div>

  <div class="max-w-7xl mx-auto px-6">

    <!-- Header -->
    <div id="feat-header" class="text-center mb-16">
      <span class="inline-block text-brand-turquoise text-sm font-semibold tracking-widest uppercase mb-4">
        Características
      </span>
      <h2 class="text-4xl md:text-5xl font-bold text-text-main mb-4">
        Todo lo que tu mascota
        <span class="text-brand-turquoise"> necesita en un lugar</span>
      </h2>
    </div>

    <!-- Cards: una fila de 4 -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {features.map((f) => (
        <div class="feat-card group relative bg-card-navy border border-text-secondary/10 rounded-2xl p-6 flex flex-col gap-4 overflow-hidden transition-all duration-300 hover:border-brand-turquoise/40 hover:shadow-[0_0_40px_rgba(62,188,164,0.08)]">

          <div class="absolute -top-6 -right-6 w-24 h-24 bg-brand-turquoise/0 group-hover:bg-brand-turquoise/10 rounded-full blur-2xl transition-all duration-500 pointer-events-none"></div>

          <div class="w-12 h-12 rounded-xl bg-brand-turquoise/10 border border-brand-turquoise/20 flex items-center justify-center text-brand-turquoise group-hover:bg-brand-turquoise/20 transition-colors duration-300">
            <Fragment set:html={f.icon} />
          </div>

          <span class="text-xs font-semibold text-brand-turquoise/70 tracking-widest uppercase">
            {f.tag}
          </span>

          <div class="flex flex-col gap-2 flex-1">
            <h3 class="text-lg font-bold text-text-main">{f.title}</h3>
            <p class="text-text-secondary text-sm leading-relaxed">{f.description}</p>
          </div>

       
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  #feat-header {
    opacity: 0;
    transform: translateY(30px);
  }
  .feat-card {
    opacity: 0;
    transform: translateY(40px);
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  ScrollTrigger.create({
    trigger: '#feat-header',
    start: 'top 85%',
    once: true,
    onEnter: () => {
      gsap.to('#feat-header', {
        opacity: 1,
        y: 0,
        duration: 0.8,
        ease: 'power3.out',
      });
    },
  });

  ScrollTrigger.create({
    trigger: '#Caracteristicas',
    start: 'top 70%',
    once: true,
    onEnter: () => {
      gsap.to(gsap.utils.toArray<HTMLElement>('.feat-card'), {
        opacity: 1,
        y: 0,
        duration: 0.6,
        ease: 'power3.out',
        stagger: 0.12,
      });
    },
  });
</script>
